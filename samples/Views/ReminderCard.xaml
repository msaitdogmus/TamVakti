<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="TamVakti.Showcase.Views.ReminderCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        Padding="18"
        BackgroundColor="{AppThemeBinding Light=#F2F7F4, Dark=#12251C}"
        Stroke="#2A4A3A"
        StrokeShape="RoundRectangle 18">

        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="{Binding Title}" />

            <Label
                Grid.Column="1"
                Text="{Binding Priority}"
                TextColor="#16C784" />

            <Label
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,8,0,0"
                Opacity="0.72"
                Text="{Binding DueAt, StringFormat='{0:dd MMM yyyy • HH:mm}'}" />
        </Grid>
    </Border>
</ContentView>
